<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Threat Digest - {{ digest_date }}</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Space+Grotesk:wght@400;500;600&display=swap");

      :root {
        --ink: #1b1c20;
        --muted: #525866;
        --accent: #f05d23;
        --accent-soft: rgba(240, 93, 35, 0.15);
        --teal: #2a7f7f;
        --low: #2d7d5a;
        --med: #c9781e;
        --high: #b01f2a;
        --card: rgba(255, 255, 255, 0.88);
        --border: rgba(27, 28, 32, 0.1);
        --shadow: 0 18px 50px rgba(22, 27, 29, 0.15);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Space Grotesk", "Noto Sans", sans-serif;
        color: var(--ink);
        background: radial-gradient(circle at top left, #f8f3ec 0%, #fdf8f2 40%, #f3f6f5 100%);
        min-height: 100vh;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background: linear-gradient(120deg, rgba(42, 127, 127, 0.12), transparent 60%),
          radial-gradient(circle at 80% 10%, rgba(240, 93, 35, 0.18), transparent 55%);
        pointer-events: none;
        z-index: -1;
      }

      header {
        padding: 3.5rem 6vw 2rem;
        display: grid;
        gap: 0.8rem;
      }

      .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.2em;
        font-size: 0.75rem;
        color: var(--teal);
        font-weight: 600;
      }

      h1 {
        font-family: "Fraunces", serif;
        font-size: clamp(2.2rem, 4vw, 3.5rem);
        margin: 0;
      }

      .subtitle {
        max-width: 48rem;
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.6;
      }

      .meta-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        font-size: 0.95rem;
        color: var(--muted);
      }

      .meta-bar span {
        background: rgba(255, 255, 255, 0.7);
        padding: 0.4rem 0.8rem;
        border-radius: 999px;
        border: 1px solid var(--border);
      }

      main {
        padding: 0 6vw 4rem;
        display: grid;
        gap: 3rem;
      }

      section {
        display: grid;
        gap: 1.5rem;
      }

      .section-title {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 1.4rem;
        font-weight: 600;
      }

      .pill {
        width: 10px;
        height: 10px;
        border-radius: 50%;
      }

      .themes,
      .one-liner {
        background: var(--card);
        border-radius: 20px;
        padding: 1.5rem;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
        display: grid;
        gap: 1rem;
      }

      .themes h2,
      .one-liner h2 {
        margin: 0;
        font-size: 1.3rem;
      }

      .themes ul {
        margin: 0;
        padding-left: 1.2rem;
        color: var(--muted);
      }

      .overview-grid {
        display: grid;
        gap: 1.5rem;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      }

      .grid {
        display: grid;
        gap: 1.5rem;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      }

      .card {
        background: var(--card);
        border-radius: 20px;
        padding: 1.5rem;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
        display: grid;
        gap: 0.9rem;
        animation: rise 0.6s ease both;
        animation-delay: calc(var(--i) * 70ms);
      }

      @keyframes rise {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .card h3 {
        margin: 0;
        font-size: 1.15rem;
      }

      .card a {
        color: var(--ink);
        text-decoration: none;
      }

      .card a:hover {
        color: var(--accent);
      }

      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 0.8rem;
        font-size: 0.85rem;
        color: var(--muted);
      }

      .chip {
        padding: 0.15rem 0.6rem;
        border-radius: 999px;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
      }

      .risk-high {
        background: rgba(176, 31, 42, 0.12);
        color: var(--high);
      }

      .risk-medium {
        background: rgba(201, 120, 30, 0.12);
        color: var(--med);
      }

      .risk-low {
        background: rgba(45, 125, 90, 0.12);
        color: var(--low);
      }

      .label-chip {
        background: rgba(42, 127, 127, 0.12);
        color: var(--teal);
      }

      .chip-neutral {
        background: rgba(27, 28, 32, 0.08);
        color: var(--muted);
      }

      .text-block {
        color: var(--muted);
        line-height: 1.6;
      }

      .hook {
        margin: 0;
        color: var(--ink);
        font-size: 1.05rem;
        line-height: 1.6;
        font-weight: 600;
      }

      .label {
        font-weight: 600;
        color: var(--ink);
      }

      .support-grid {
        display: grid;
        gap: 0.85rem;
      }

      .story-list {
        background: rgba(255, 255, 255, 0.6);
        border-radius: 12px;
        padding: 0.8rem 1rem;
        margin: 0;
        color: var(--muted);
        line-height: 1.6;
      }

      .story-list li {
        margin: 0.35rem 0;
      }

      .glossary {
        background: rgba(255, 255, 255, 0.7);
        padding: 0.9rem 1rem;
        border-radius: 12px;
        border: 1px solid var(--border);
      }

      .glossary .label {
        display: block;
        margin-bottom: 0.4rem;
      }

      .list {
        margin: 0.3rem 0 0;
        padding-left: 1.2rem;
        color: var(--muted);
      }

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        font-size: 0.8rem;
        color: var(--teal);
      }

      .tags span {
        background: rgba(42, 127, 127, 0.12);
        padding: 0.2rem 0.6rem;
        border-radius: 999px;
      }

      .confidence {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--muted);
      }

      .sources {
        display: grid;
        gap: 0.3rem;
        font-size: 0.85rem;
      }

      .sources a {
        color: var(--ink);
        text-decoration: none;
      }

      .sources a:hover {
        color: var(--accent);
      }

      .empty {
        margin: 0;
        color: var(--muted);
      }

      .archive {
        padding: 2rem 6vw 4rem;
        border-top: 1px solid var(--border);
        display: grid;
        gap: 1rem;
      }

      .archive-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.7rem;
      }

      .archive-list a {
        text-decoration: none;
        color: var(--ink);
        background: rgba(255, 255, 255, 0.8);
        padding: 0.4rem 0.8rem;
        border-radius: 999px;
        border: 1px solid var(--border);
      }

      footer {
        padding: 0 6vw 3rem;
        color: var(--muted);
        font-size: 0.85rem;
      }

      @media (max-width: 720px) {
        header {
          padding: 2.5rem 7vw 1.5rem;
        }

        main {
          padding: 0 7vw 3rem;
        }

        .meta-bar {
          flex-direction: column;
          align-items: flex-start;
        }
      }

      @media (min-width: 900px) {
        .support-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }
    </style>
  </head>
  <body>
    {% macro cluster_card(item, index) -%}
      <article class="card" style="--i: {{ index }};">
        <div class="meta">
          <span class="chip risk-{{ item.risk | lower }}">{{ item.risk }}</span>
          {% for label in item.labels %}
            <span class="chip label-chip">{{ label.replace('_', ' ') }}</span>
          {% endfor %}
          <span class="chip chip-neutral">{{ item.attack_stage }}</span>
          <span class="chip chip-neutral">Confidence {{ item.confidence }}</span>
        </div>
        {% if item.primary_url %}
          <h3><a href="{{ item.primary_url }}" target="_blank" rel="noopener noreferrer">{{ item.cluster_title }}</a></h3>
        {% else %}
          <h3>{{ item.cluster_title }}</h3>
        {% endif %}
        <p class="hook">{{ item.hook }}</p>
        <div class="support-grid">
          <div class="text-block"><span class="label">Who should care:</span> {{ item.who_should_care }}</div>
          <div class="text-block"><span class="label">Attack path:</span> {{ item.attacker_path }}</div>
        </div>
        <div class="text-block"><span class="label">Why this matters now:</span> {{ item.why_this_is_here }}</div>
        <div class="text-block"><span class="label">In plain English:</span> {{ item.tl_dr }}</div>
        {% if item.tags %}
          <div class="tags">
            {% for tag in item.tags %}
              <span>{{ tag.replace('-', ' ') }}</span>
            {% endfor %}
          </div>
        {% endif %}
        <ul class="story-list">
          {% for line in item.story_lines %}
            <li>{{ line }}</li>
          {% endfor %}
        </ul>

        {% if item.beginner_breakdown %}
          <div class="glossary">
            <div class="label">Key terms</div>
            <ul class="list">
            {% for entry in item.beginner_breakdown %}
              <li>{{ entry }}</li>
            {% endfor %}
            </ul>
          </div>
        {% endif %}

        <div>
          <div class="label">Defender focus</div>
          <ul class="list">
            {% for focus in item.soc_focus %}
            <li>{{ focus }}</li>
            {% endfor %}
          </ul>
        </div>

        <div>
          <div class="label">Do now</div>
          <ul class="list">
            {% for action in item.recommended_actions %}
            <li>{{ action }}</li>
            {% endfor %}
          </ul>
        </div>

        <div class="text-block"><span class="label">Watch next:</span> {{ item.watch_next }}</div>

        <div class="sources">
          <div class="label">Sources</div>
          {% for source in item.sources %}
            {% if source.url %}
              <div>
                <a href="{{ source.url }}" target="_blank" rel="noopener noreferrer">
                  {{ source.source }} - {{ source.title }}
                </a>
              </div>
            {% else %}
              <div>{{ source.source }} - {{ source.title }}</div>
            {% endif %}
          {% endfor %}
        </div>
      </article>
    {%- endmacro %}

    <header>
      <div class="eyebrow">Daily Threat Briefing</div>
      <h1>Threat Digest - {{ digest_date }}</h1>
      <p class="subtitle">
        The security news worth your attention, with context and practical takeaways.
      </p>
      <div class="meta-bar">
        <span>Updated: {{ generated_at }}</span>
        <span>Stories: {{ editorial.all_clusters | length }}</span>
        <span>Recent issues: {{ archive_links | length }}</span>
      </div>
    </header>

    <main>
      <div class="overview-grid">
        <section class="one-liner">
          <h2>What Matters Today</h2>
          {% if themes_data %}
            <p class="text-block">{{ themes_data.today_in_one_sentence }}</p>
          {% else %}
            <p class="empty">No summary available yet.</p>
          {% endif %}
        </section>

        <section class="themes">
          <h2>Patterns To Watch</h2>
          {% if themes_data %}
            <ul>
              {% for theme in themes_data.themes %}
              <li>{{ theme }}</li>
              {% endfor %}
            </ul>
          {% else %}
            <p class="empty">No themes available yet.</p>
          {% endif %}
        </section>
      </div>

      <section>
        <div class="section-title">
          <span class="pill" style="background: var(--high);"></span>
          Start Here
        </div>
        {% if editorial.top_story %}
          <div class="grid">
            {{ cluster_card(editorial.top_story, 0) }}
          </div>
        {% else %}
          <p class="empty">No priority story yet.</p>
        {% endif %}
      </section>

      <section>
        <div class="section-title">
          <span class="pill" style="background: var(--med);"></span>
          Priority Watchlist
        </div>
        {% if editorial.top_three %}
          <div class="grid">
            {% for item in editorial.top_three %}
              {{ cluster_card(item, loop.index0) }}
            {% endfor %}
          </div>
        {% else %}
          <p class="empty">No additional top stories.</p>
        {% endif %}
      </section>

      <section>
        <div class="section-title">
          <span class="pill" style="background: var(--low);"></span>
          Wider Signal
        </div>
        {% if editorial.context %}
          <div class="grid">
            {% for item in editorial.context %}
              {{ cluster_card(item, loop.index0) }}
            {% endfor %}
          </div>
        {% else %}
          <p class="empty">No context stories today.</p>
        {% endif %}
      </section>
    </main>

    <aside class="archive">
      <strong>Recent Issues</strong>
      <div class="archive-list">
        {% for archive_date in archive_links %}
        <a href="archive/{{ archive_date }}.html">{{ archive_date }}</a>
        {% endfor %}
      </div>
    </aside>

    <footer>
      Generated by the Threat Digest pipeline from RSS feeds and structured summaries.
    </footer>

  </body>
</html>
